create extension if not exists "uuid-ossp";

create table if not exists public.orders (
  id uuid primary key default uuid_generate_v4(),
  stripe_session_id text,
  customer_email text,
  status text default 'checkout_created',
  total_cents integer default 0,
  items jsonb default '[]'::jsonb,
  tracking_number text,
  shipping_address jsonb,
  consent_accepted boolean default true,
  created_at timestamptz default now(),
  updated_at timestamptz default now()
);

create table if not exists public.inventory (
  sku text primary key,
  name text not null,
  on_hand integer default 0,
  reorder_level integer default 10,
  updated_at timestamptz default now()
);

insert into public.inventory (sku, name, on_hand, reorder_level) values
('nad-rejuvenate','Rejuvenate NAD+',100,20),
('tirzepatide-strip','Tirzepatide Strip',100,20),
('pt141-oxytocin','PT-141 / Oxytocin',100,20),
('bpc157-strip','BPC-157 Strip',100,20),
('ghkcu-strip','GHK-Cu Strip',100,20),
('glutathione-strip','Glutathione Strip',100,20)
on conflict (sku) do nothing;

alter table public.orders enable row level security;
alter table public.inventory enable row level security;
