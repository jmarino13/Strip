:root{--bg:#030303;--card:#0b0b0f;--gold:#d5a447;--purple:#8d56dd;--text:#f6f1ea;--muted:#b9b2c4}*{box-sizing:border-box}body{margin:0;background:radial-gradient(circle at top,#17101f,#030303 45%);color:var(--text);font-family:Arial,Helvetica,sans-serif;letter-spacing:.04em}.nav{display:flex;align-items:center;justify-content:space-between;padding:24px 6vw;border-bottom:1px solid #201c25;background:#050505cc;position:sticky;top:0;z-index:5}.brand{display:flex;align-items:center;gap:14px;font-weight:700;color:var(--gold);font-size:24px}.brand img{width:58px;height:58px;object-fit:cover;border-radius:50%}.nav a{color:white;text-decoration:none;margin-left:24px}.btn{border:0;border-radius:999px;padding:14px 22px;background:linear-gradient(90deg,var(--gold),#f4d07a);color:#050505;font-weight:800;cursor:pointer}.btn.secondary{background:linear-gradient(90deg,var(--purple),#c4a1ff);color:white}.hero{display:grid;grid-template-columns:1.1fr .9fr;gap:40px;align-items:center;padding:70px 6vw}.hero h1{font-size:64px;line-height:1;letter-spacing:.14em;margin:0}.hero h1 span{color:var(--purple)}.hero p{color:var(--muted);font-size:19px;line-height:1.7;max-width:760px}.hero img,.product img{width:100%;border-radius:28px;border:1px solid #2c2535;box-shadow:0 0 60px #6c30cc33}.strip{color:var(--gold)}.section{padding:55px 6vw}.eyebrow{color:var(--purple);font-weight:800}.grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px}.card,.product{background:linear-gradient(180deg,#0d0d12,#050505);border:1px solid #2a2530;border-radius:24px;padding:24px;box-shadow:0 0 30px #000}.card h3,.product h3{color:var(--gold)}.product{display:flex;flex-direction:column;gap:12px}.price{font-size:24px;color:white;font-weight:800}.fine{font-size:12px;color:#aaa;line-height:1.6}.checkout{display:flex;gap:10px;align-items:center}.checkout input{width:70px;background:#050505;border:1px solid #40354d;color:white;padding:12px;border-radius:12px}.admin table{width:100%;border-collapse:collapse}.admin th,.admin td{border-bottom:1px solid #2b2530;padding:14px;text-align:left}.footer{padding:35px 6vw;color:#aaa;border-top:1px solid #211c28}.notice{border:1px solid var(--purple);background:#160d22;border-radius:20px;padding:22px;color:#ddd}@media(max-width:850px){.hero,.grid{grid-template-columns:1fr}.hero h1{font-size:42px}.nav{display:block}.nav a{display:inline-block;margin:12px 16px 0 0}}
