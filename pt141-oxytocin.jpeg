'use client';
import { products } from '@/lib/products';
import { useState } from 'react';
export default function Home(){
 const [loading,setLoading]=useState('');
 async function checkout(id:string,qty:number){setLoading(id); const res=await fetch('/api/checkout',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id,qty})}); const data=await res.json(); if(data.url) location.href=data.url; else alert(data.error||'Checkout unavailable'); setLoading('');}
 return <main><section className="hero"><div><p className="eyebrow">THE FUTURE OF PEPTIDE WELLNESS</p><h1><span>ABSORB</span> MORE.<br/>ACHIEVE MORE.<br/><span className="strip">BE MORE.</span></h1><p>STRIP sells medical-grade peptide dissolvable strips designed for sublingual delivery through the salivary glands. This delivery method helps bypass stomach acid, offering stronger absorption than capsules while remaining a needle-free alternative to injections.</p><button className="btn" onClick={()=>document.getElementById('shop')?.scrollIntoView({behavior:'smooth'})}>Shop Strips</button></div><img src="/assets/strip-hero.jpeg"/></section><section id="science" className="section grid"><div className="card"><h3>Sublingual Delivery</h3><p>Dissolvable oral strip technology designed to dissolve under the tongue and support faster absorption than traditional capsules.</p></div><div className="card"><h3>Needle-Free Wellness</h3><p>Created for clients who want a premium peptide experience without daily injections.</p></div><div className="card"><h3>Clinical Workflow</h3><p>Consent, eligibility review, inventory tracking, order status, and fulfillment updates are built into the backend plan.</p></div></section><section className="section"><div className="notice"><b>Required before fulfillment:</b> customer consent/waiver, payment confirmation, inventory availability, and clinic approval when applicable.</div></section><section id="shop" className="section"><p className="eyebrow">ONLINE CATALOG</p><h2>Peptide Strip Products</h2><div className="grid">{products.map(p=><Product key={p.id} p={p} loading={loading} checkout={checkout}/>)}</div></section></main>}
function Product({p,loading,checkout}:any){const [qty,setQty]=useState(1);return <div className="product"><img src={p.image}/><h3>{p.name}</h3><p>{p.description}</p><div className="price">${(p.price/100).toFixed(0)}</div><label className="fine"><input type="checkbox" required/> I agree to complete the STRIP peptide consent/waiver before fulfillment.</label><div className="checkout"><input type="number" min="1" value={qty} onChange={e=>setQty(Number(e.target.value))}/><button className="btn secondary" onClick={()=>checkout(p.id,qty)}>{loading===p.id?'Loading...':'Buy Now'}</button></div></div>}
